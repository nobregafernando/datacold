{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/.*/**",
      "**/node_modules/**",
      "**/__pycache__/**",
      "**/*.md",
      "**/*.py",
      "**/*.pyc",
      "**/*.db",
      "**/*.db-*",
      "**/*.sql",
      "**/*.apk",
      "**/*.aab",
      "**/*.ipa",
      "**/*.exe",
      "**/*.sh",
      "scripts/build/**",
      "estudos/explorador-api.html",
      "simulador/**",
      "supabase/**",
      "app_flutter/**"
    ],
    "cleanUrls": true,
    "trailingSlash": true,
    "predeploy": [
      "node scripts/build/versionar.js"
    ],
    "headers": [
      {
        "source": "**/*.@(html|js|css|json)",
        "headers": [
          { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
          { "key": "Pragma", "value": "no-cache" },
          { "key": "Expires", "value": "0" }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|gif|webp|svg|ico)",
        "headers": [
          { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
          { "key": "Pragma", "value": "no-cache" },
          { "key": "Expires", "value": "0" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
          { "key": "Pragma", "value": "no-cache" },
          { "key": "Expires", "value": "0" }
        ]
      }
    ]
  }
}
