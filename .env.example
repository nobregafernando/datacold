# =============================================================================
#  DataCold · variáveis de ambiente (server-side only — NUNCA expor no front)
# =============================================================================
# Copie pra `.env` (já está no .gitignore) e preencha com os valores reais.
#
#  - O `.env` é usado por scripts Python (supabase/aplicar.py),
#    e pela CLI do Supabase (supabase secrets set --env-file .env).
#  - O FRONT NÃO LÊ esse arquivo; ele chama só a Edge Function "proxy",
#    que lê as variáveis SB_* / BEM_* a partir do ambiente Supabase.
# =============================================================================

# --- Postgres do Supabase (usado por aplicar.py) ---
SUPABASE_PROJECT_ID=
SUPABASE_DB_PASSWORD=

# --- Chaves do Supabase ---
# Pegue em https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=          # service_role — NUNCA usar no browser

# --- Edge Function "proxy" (configurar via `supabase secrets set --env-file .env`) ---
SB_URL=https://<projeto>.supabase.co
SB_ANON_KEY=                  # mesmo valor de SUPABASE_ANON_KEY
BEM_API_KEY=                  # opcional — chave da API BEM real (se quiser usar)

# --- Token pra automação via Supabase CLI (gerar em https://supabase.com/dashboard/account/tokens) ---
SUPABASE_ACCESS_TOKEN=

# Resend — envio transacional de email (convites, recuperação)
# Crie a chave em https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Remetente. Em testes o sandbox "onboarding@resend.dev" só envia pro dono
# da conta Resend. Em produção, verificar domínio em https://resend.com/domains
# e setar pra "DataCold <noreply@seu-dominio.com>".
RESEND_FROM=DataCold <onboarding@resend.dev>
